---
profile: moderate

# Paths to exclude from linting
exclude_paths:
  - .git/
  - archive/
  - example_inventory.yml
  - reboot_vms.yml
  - standalone_tasks/

# Rules to skip that don't apply to this project
skip_list:
  - yaml[line-length] # Long podman run commands are unavoidable
  - name[template] # Template expressions in task names are acceptable here

# Warn-only rules (don't fail CI, just report)
warn_list:
  - experimental

# Enable these rule sets
use_default_rules: true
