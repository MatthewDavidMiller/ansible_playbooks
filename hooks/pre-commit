#!/bin/bash
# Pre-commit hook: runs ansible-lint and syntax checks for maintained playbooks.
# Install: git config core.hooksPath hooks
# Skip:    git commit --no-verify

set -euo pipefail

echo "=== Pre-commit checks ==="

echo ""
echo "--- Supply Chain Policy ---"
bash scripts/test_supply_chain_policy.sh
echo "PASS: supply-chain policy"

echo ""
echo "--- Ansible Lint ---"
ansible-lint
echo "PASS: ansible-lint"

echo ""
echo "--- Ansible Syntax Check ---"
for playbook in vm1.yml homelab_vms.yml update_homelab_vms.yml reboot_vms.yml; do
  [ -f "$playbook" ] || continue
  ansible-playbook --syntax-check -i example_inventory.yml "$playbook"
done
echo "PASS: ansible syntax check"

echo ""
echo "=== All checks passed ==="
