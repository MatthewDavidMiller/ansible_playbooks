{% set navidrome_music_path = navidrome_local_music_path | default(navidrome_path + '/music', true) %}
[Unit]
Description=Podman container-navidrome.service
Documentation=man:podman-generate-systemd(1)
Wants=network-online.target
After=network-online.target
RequiresMountsFor={{ navidrome_music_path }}
{% if nextcloud_path | default('', true) and navidrome_music_path.startswith(nextcloud_path ~ '/data/') %}
After=nextcloud_container.service
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=on-failure
TimeoutStopSec=70
ExecStartPre=/usr/bin/podman rm --ignore navidrome
ExecStartPre=/usr/bin/bash -c 'for attempt in {1..60}; do [ -d "$1" ] && [ -r "$1" ] && exit 0; sleep 5; done; echo "Timed out waiting for Navidrome music path: $1" >&2; exit 1' _ {{ navidrome_music_path | quote }}
ExecStart=/usr/bin/bash /usr/local/bin/navidrome_container.sh
RestartSec=10
TimeoutStartSec=300
ExecStop=/usr/bin/podman stop --ignore navidrome
ExecStopPost=/usr/bin/podman rm --ignore -f navidrome
Type=forking

[Install]
WantedBy=multi-user.target default.target
