#!/bin/bash
set -euo pipefail

/usr/bin/podman run \
--pull=never \
--name navidrome \
--network=navidrome_container_net:alias={{ container_dns.aliases.navidrome_proxy }} \
--user {{ navidrome_uid }}:{{ navidrome_gid }} \
--volume {{ navidrome_local_music_path | default(navidrome_path + '/music', true) }}:/music:ro,z \
--volume {{ navidrome_path }}/data:/data:Z \
--volume {{ navidrome_path }}/backup:/navidrome_backup:Z \
--read-only \
--tmpfs /tmp:rw,noexec,nosuid,nodev,size=16m \
-e ND_LOGLEVEL=info \
-e TZ=America/New_York \
-e ND_BACKUP_PATH=/navidrome_backup \
--memory=256m \
--memory-swap=256m \
--pids-limit=200 \
--cap-drop=ALL \
--security-opt=no-new-privileges:true \
-d {{ navidrome_image }}
