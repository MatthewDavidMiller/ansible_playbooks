POSTGRES_DB={{ nextcloud_database_name | quote }}
POSTGRES_USER={{ nextcloud_db_user | quote }}
POSTGRES_PASSWORD={{ nextcloud_db_password | quote }}
NEXTCLOUD_ADMIN_USER={{ nextcloud_admin_user | quote }}
NEXTCLOUD_ADMIN_PASSWORD={{ nextcloud_admin_password | quote }}
NEXTCLOUD_TRUSTED_DOMAINS={{ nextcloud_trusted_domains | quote }}
POSTGRES_HOST={{ (container_dns.aliases.postgres_backend ~ '.' ~ container_dns.domain) | quote }}
