OVERWRITECLIURL={{ ('https://' ~ nextcloud_dns_name) | quote }}
PHP_UPLOAD_LIMIT={{ '20480M' | quote }}
APACHE_BODY_LIMIT={{ '21474836480' | quote }}
REDIS_HOST={{ (container_dns.aliases.redis_backend ~ '.' ~ container_dns.domain) | quote }}
TZ={{ 'America/New_York' | quote }}
