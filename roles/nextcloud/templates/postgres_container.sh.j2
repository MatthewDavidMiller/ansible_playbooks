/usr/bin/podman pull {{ postgres_image }}
/usr/bin/podman run \
--name=postgres \
--user=999:999 \
--network=nextcloud_container_net \
--volume {{ postgres_path }}/pgdata:/var/lib/postgresql/data/:Z \
--volume {{ postgres_path }}/custom-init:/custom-init/:Z \
--env-file {{ secret_env_dir }}/postgres.env \
--entrypoint /custom-init/db_wrapper.sh \
--memory=2g \
--memory-swap=2g \
--shm-size=256m \
--cap-drop=ALL \
--security-opt=no-new-privileges:true \
-d {{ postgres_image }}
