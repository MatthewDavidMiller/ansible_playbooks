/usr/bin/podman pull {{ redis_image }}
/usr/bin/podman run \
--name=redis \
--network=nextcloud_container_net \
--env-file {{ secret_env_dir }}/redis.env \
--memory=256m \
--memory-swap=256m \
--cap-drop=ALL \
--cap-add=CHOWN \
--cap-add=FOWNER \
--cap-add=DAC_OVERRIDE \
--security-opt=no-new-privileges:true \
-d {{ redis_image }}
