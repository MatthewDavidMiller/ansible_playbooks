http:
  routers:
    traefik-dashboard:
      rule: "Host(`{{ traefik_dashboard_fqdn }}`) && (PathPrefix(`/api`) || PathPrefix(`/dashboard`))"
      entryPoints:
        - websecure
      service: api@internal
      tls: {}
      middlewares:
        - ip-allowlist-mgmt@file
        - security-headers@file
