http:
  middlewares:
    security-headers:
      headers:
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        stsPreload: true
        frameDeny: true
        contentTypeNosniff: true
        browserXssFilter: true
        referrerPolicy: strict-origin-when-cross-origin
        customResponseHeaders:
          X-Powered-By: ""

    ip-allowlist-mgmt:
      ipAllowList:
        sourceRange:
{% for net in management_network %}
          - "{{ net }}"
{% endfor %}
          - "{{ ip_ansible }}"

    dashboard-basic-auth:
      basicAuth:
        users:
{% for user in traefik_dashboard_basic_auth_users %}
          - "{{ user }}"
{% endfor %}

    rate-limit-default:
      rateLimit:
        average: 100
        burst: 50
