[Unit]
Description=Podman container-traefik.service
Wants=network.target
After=network-online.target{% for service_name in container_service_names.split() %} {{ service_name }}.service{% endfor %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=on-failure
TimeoutStopSec=70
ExecStartPre=/usr/bin/podman rm --ignore traefik
ExecStart=/usr/bin/bash /usr/local/bin/traefik_container.sh
RestartSec=10
TimeoutStartSec=300
ExecStop=/usr/bin/podman stop --ignore traefik
ExecStopPost=/usr/bin/podman rm --ignore -f traefik
Type=forking

[Install]
WantedBy=multi-user.target default.target
