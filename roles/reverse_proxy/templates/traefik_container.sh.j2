#!/bin/bash
set -euo pipefail

set -a
. "{{ secret_env_dir }}/traefik.env"
set +a

exec /usr/bin/podman run \
  --pull=never \
  --name=traefik \
{% for net in traefik_networks %}
  --network={{ net }} \
{% endfor %}
  --env PORKBUN_API_KEY \
  --env PORKBUN_SECRET_API_KEY \
  -v {{ traefik_path }}/traefik.yml:/etc/traefik/traefik.yml:Z,ro \
  -v {{ traefik_path }}/config:/etc/traefik/config:Z,ro \
  -v {{ traefik_path }}/acme.json:/acme.json:Z \
  -p 80:80/tcp \
  -p 443:443/tcp \
  --memory=256m \
  --memory-swap=256m \
  --cap-drop=ALL \
  --cap-add=NET_BIND_SERVICE \
  --security-opt=no-new-privileges:true \
  -d {{ traefik_image }}
