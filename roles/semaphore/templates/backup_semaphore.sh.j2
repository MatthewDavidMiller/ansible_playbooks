#!/bin/bash
set -euo pipefail

umask 077

timestamp=$(date +%m_%d_%Y)
TMP_DIR=$(mktemp -d /tmp/semaphore-backup.XXXXXX)
trap 'rm -rf "$TMP_DIR"' EXIT
DUMP_FILE="${TMP_DIR}/semaphore_db_${timestamp}.sql"

/usr/bin/podman exec postgres pg_dump \
  -U {{ postgres_admin_user }} {{ semaphore_database_name }} \
  > "$DUMP_FILE"

{% if backup_local | default(false) %}
DEST="{{ nextcloud_path }}/data/{{ nextcloud_homelab_user }}/files/{{ semaphore_backup_location | replace('Nextcloud:', '') }}"
/usr/bin/install -d -o {{ nextcloud_uid }} -g {{ nextcloud_gid }} -m 0770 "$DEST"
/usr/bin/install -o {{ nextcloud_uid }} -g {{ nextcloud_gid }} -m 0640 "$DUMP_FILE" "$DEST/"
/usr/bin/podman exec nextcloud php occ files:scan \
    --path="{{ nextcloud_homelab_user }}/files/{{ semaphore_backup_location | replace('Nextcloud:', '') }}" \
    >> /var/log/semaphore_backup.log 2>&1 || true
{% else %}
/usr/bin/rclone copy "$DUMP_FILE" Nextcloud:{{ semaphore_backup_location }}
{% endif %}

/usr/bin/rm "$DUMP_FILE"
