#!/bin/bash
set -euo pipefail

set -a
. "{{ secret_env_dir }}/semaphore.env"
set +a

exec /usr/bin/podman run \
--pull=never \
--name semaphore \
--env SEMAPHORE_DB_DIALECT \
--env SEMAPHORE_DB_HOST \
--env SEMAPHORE_DB_NAME \
--env SEMAPHORE_DB_USER \
--env SEMAPHORE_DB_PASS \
--env SEMAPHORE_ADMIN \
--env SEMAPHORE_ADMIN_PASSWORD \
--env SEMAPHORE_ADMIN_NAME \
--env SEMAPHORE_ADMIN_EMAIL \
--env SEMAPHORE_ACCESS_KEY_ENCRYPTION \
--env ANSIBLE_SSH_ARGS \
--env TZ \
--network=nextcloud_container_net:ip={{ container_static_ips.semaphore_backend }},alias={{ container_dns.aliases.semaphore_backend }} \
--network=semaphore_container_net:ip={{ container_static_ips.semaphore_proxy }},alias={{ container_dns.aliases.semaphore_proxy }} \
--network={{ semaphore_egress_network }}:alias={{ container_dns.aliases.semaphore_egress }} \
--add-host={{ container_dns.aliases.postgres_backend }}.{{ container_dns.domain }}:{{ container_static_ips.postgres_backend }} \
--volume /etc/semaphore:/etc/semaphore:Z \
--volume /var/lib/semaphore:/var/lib/semaphore:Z \
--read-only \
--tmpfs /tmp:rw,noexec,nosuid,nodev,size=64m \
--mount type=tmpfs,destination=/home/semaphore,tmpfs-size=32M,tmpfs-mode=0750,U=true \
--mount type=tmpfs,destination=/tmp/semaphore,tmpfs-size=64M,tmpfs-mode=0750,U=true \
--memory=384m \
--memory-swap=384m \
--pids-limit=300 \
--cap-drop=ALL \
--security-opt=no-new-privileges:true \
-d {{ semaphore_image }}
