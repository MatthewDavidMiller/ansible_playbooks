#!/bin/bash
set -euo pipefail

/usr/bin/podman run \
--pull=never \
--name=vaultwarden \
--network=vaultwarden_container_net \
--volume {{ vaultwarden_path }}/vw-data:/data/:Z \
--volume {{ vaultwarden_path }}/ssl_certs:/ssl_certs/:Z \
--read-only \
--tmpfs /tmp:rw,noexec,nosuid,nodev,size=16m \
-e TZ=America/New_York \
-e SIGNUPS_ALLOWED={{ vaultwarden_signups_allowed | ternary('true', 'false') }} \
--memory=256m \
--memory-swap=256m \
--pids-limit=200 \
--cap-drop=ALL \
--cap-add=NET_BIND_SERVICE \
--security-opt=no-new-privileges:true \
-d {{ vaultwarden_image }}
